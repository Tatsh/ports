PortSystem          1.0
PortGroup           github 1.0
PortGroup           xcode 1.0

if {${os.major} < 20} {
    github.setup        waylybaye XcodeCleaner-SwiftUI cc8c942
    version             3.1.1
    livecheck.type      none
} else {
    # This SHA supports Xcode 15.2.
    github.setup        waylybaye XcodeCleaner-SwiftUI cc9a4b9
    version             4.0.6
    revision            0
}

name                cleaner-for-xcode
categories          devel aqua
license             Restricted
maintainers         {gmail.com:audvare @Tatsh}

description         This app helps you to make your Xcode faster by removing \
                    unwanted and deprecated files.
long_description    ${description}

if {${os.major} >= 20} {
    checksums           rmd160  e87b7ad4a2b2745c48c487ece17ee73cfb6575df \
                        sha256  15b5002e8bdbdad3759c5abc21a4b2777711ec1fc11be69b15492b0e20e6328a \
                        size    3281107
} else {
    checksums           rmd160  bb90fbe23852eb579d60ec89e9a4858a0e8e62d3 \
                        sha256  9b78e03e67a177aea561b7b47dd45a39932345659f007e2bb908d3e45d95d416 \
                        size    1465192
}

xcode.target        "Cleaner for Xcode"
xcode.configuration Release
xcode.build.settings    SDKROOT=macosx
xcode.destroot.settings \
    SDKROOT=macosx \
    CODE_SIGN_IDENTITY=- \
    CODE_SIGN_STYLE=Manual

if {${os.major} < 19} {
    pre-fetch {
        ui_error "${name} @${version} requires macOS 10.15 or later."
        return -code error "incompatible OS X version"
    }
}

# Compile and install in one step, for now. See https://trac.macports.org/ticket/57137
build {}
