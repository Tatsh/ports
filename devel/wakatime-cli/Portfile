pre-build {
    # viper imports go.yaml.in/yaml/v3; alias v3 subdir to gopkg.in/yaml.v3
    file mkdir ${workpath}/gopath/src/go.yaml.in
    file mkdir ${workpath}/gopath/src/go.yaml.in/yaml
    catch {file delete -force ${workpath}/gopath/src/go.yaml.in/yaml/v3}
    ln -s ${workpath}/gopath/src/gopkg.in/yaml.v3 \
        ${workpath}/gopath/src/go.yaml.in/yaml/v3
    # encoding/ini tarball contains full repo; move ini subdir contents up
    set encIni ${workpath}/gopath/src/github.com/go-viper/encoding/ini
    if {[file isdirectory ${encIni}/ini]} {
        foreach f [glob -nocomplain -directory ${encIni}/ini *] {
            file rename -force ${f} ${encIni}/
        }
        file delete -force ${encIni}/ini
        foreach d {dotenv hcl javaproperties toml yaml .github} {
            catch {file delete -force ${encIni}/${d}}
        }
        foreach f {.editorconfig .envrc .gitignore .golangci.yaml flake.lock flake.nix go.mod go.work justfile LICENSE README.md} {
            catch {file delete -force ${encIni}/${f}}
        }
    }
    if {${build_arch} eq "x86_64"} {
        build.target build-darwin-amd64
    } elseif {${build_arch} eq "i386"} {
        build.target build-darwin-386
    } elseif {${build_arch} eq "arm64"} {
        build.target build-darwin-arm64
    } else {
        return -code error "incompatible arch"
    }
}

build.cmd       make

destroot {
    xinstall -m 0755 {*}[glob ${worksrcpath}/build/${name}-darwin-*] \
        ${destroot}${prefix}/bin/${name}
}
