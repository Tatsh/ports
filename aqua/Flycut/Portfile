# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0
PortGroup           github 1.0
PortGroup           xcode 1.0

github.setup        TermiT Flycut 1.9.6
# Use source tarball from tag; release asset returns 404
github.tarball_from tarball
revision            4

categories-append   sysutils
license             GPL-3
maintainers         {gmail.com:audvare @Tatsh}
description         Flycut is a clean and simple clipboard manager for developers.
long_description    ${description}

checksums           rmd160  1840df6ca97f77b1342778ed19be0a7892dc5750 \
                    sha256  72b5da825b73da3d18381c49229c1d6a9258bad015717e5fbb4523fb4e447515 \
                    size    3104683

depends_build       port:git

patch.cmd           ${prefix}/bin/git
patch.pre_args      apply --binary -p0 -
patchfiles          patch-remove-icloud-support.diff

xcode.scheme        ${name}
xcode.configuration Release
xcode.build.settings \
    SDKROOT=macosx \
    ASSETCATALOG_COMPILER_GENERATE_ASSET_SYMBOLS=NO \
    CODE_SIGN_IDENTITY=- \
    CODE_SIGN_STYLE=Manual \
    PROVISIONING_PROFILE_SPECIFIER= \
    DEVELOPMENT_TEAM= \
    ENABLE_HARDENED_RUNTIME=NO
xcode.destroot.settings \
    SDKROOT=macosx \
    OBJROOT=${workpath}/obj \
    SYMROOT=${workpath}/sym \
    ASSETCATALOG_COMPILER_GENERATE_ASSET_SYMBOLS=NO \
    CODE_SIGN_IDENTITY=- \
    CODE_SIGN_STYLE=Manual \
    PROVISIONING_PROFILE_SPECIFIER= \
    DEVELOPMENT_TEAM= \
    ENABLE_HARDENED_RUNTIME=NO

# Use workpath for build outputs so actool and other tools write to writable dirs.
destroot.pre_args   -derivedDataPath ${workpath}/.dd
destroot.env-append \
    OBJROOT=${workpath}/obj \
    SYMROOT=${workpath}/sym \
    TMPDIR=${workpath}/tmp
pre-destroot {
    foreach d { .dd obj sym tmp } {
        file mkdir ${workpath}/${d}
    }
    catch { exec chmod -R u+rwx,g+rwx,o+rwx ${workpath}/obj ${workpath}/sym ${workpath}/.dd ${workpath}/tmp }
}

# Compile and install in one step, for now. See https://trac.macports.org/ticket/57137
build {}

if {${os.major} < 17} {
    pre-fetch {
        ui_error "Building ${name} @${version} requires macOS 10.13 or later."
        return -code error "incompatible macOS version"
    }
}
