PortSystem          1.0

PortGroup           github 1.0
PortGroup           xcode 1.0

github.setup        gao-sun eul 1.6.2 v
# Release asset returns 403; use source tarball from tag
github.tarball_from tarball

categories          aqua sysutils
platforms           macosx
maintainers         {gmail.com:audvare @Tatsh} openmaintainer
license             GPL-2
supported_archs     arm64 x86_64

description         macOS status monitoring app written in SwiftUI.
long_description    ${description}

checksums           rmd160  0e87a2219bad6638d56f7291127aa7bae1645e23 \
                    sha256  7092b0f9be7e7c888e621cc024946d93bb725484bb541cf763f66e9d56be1f52 \
                    size    1188588

depends_lib \
    port:SystemKit \
    port:SwiftyJSON \
    port:Localize-Swift \
    port:LaunchAtLogin

if {${os.major} < 19} {
    known_fail      yes
    pre-fetch {
        ui_error "${name} requires macOS 10.15 or later."
        return -code error "incompatible macOS version"
    }
}

patchfiles patch-deps.diff

xcode.configuration Release
xcode.scheme        ${name}
xcode.build.settings    SDKROOT=macosx \
    ASSETCATALOG_COMPILER_GENERATE_SWIFT_ASSET_SYMBOL_EXTENSIONS=NO \
    ASSETCATALOG_COMPILER_GENERATE_ASSET_SYMBOLS=NO
xcode.destroot.settings \
    SDKROOT=macosx \
    CODE_SIGN_IDENTITY=- \
    CODE_SIGN_STYLE=Manual \
    ENABLE_HARDENED_RUNTIME=NO \
    ASSETCATALOG_COMPILER_GENERATE_SWIFT_ASSET_SYMBOL_EXTENSIONS=NO \
    ASSETCATALOG_COMPILER_GENERATE_ASSET_SYMBOLS=NO \
    OBJROOT=/tmp/eul-build \
    SYMROOT=/tmp/eul-build

# Compile and install in one step, for now. See https://trac.macports.org/ticket/57137
# Use /tmp for DSTROOT so actool (sandboxed) can write; then copy to real destroot.
build {}

pre-destroot {
    catch {file delete -force /tmp/eul-build}
    file mkdir /tmp/eul-build/Release
    catch {file delete -force /tmp/eul-destroot}
    file mkdir /tmp/eul-destroot
}

destroot {
    set tmp_dstroot /tmp/eul-destroot
    set xcode_settings "INSTALL_PATH=${applications_dir} OBJROOT=/tmp/eul-build SYMROOT=/tmp/eul-build DSTROOT=${tmp_dstroot} MACOSX_DEPLOYMENT_TARGET=${macosx_deployment_target} ARCHS=${configure.build_arch} SDKROOT=${configure.sdkroot} GCC_VERSION=com.apple.compilers.llvm.clang.1_0 CLANG_CXX_LIBRARY=libc++ SDKROOT=macosx CODE_SIGN_IDENTITY=- CODE_SIGN_STYLE=Manual ENABLE_HARDENED_RUNTIME=NO ASSETCATALOG_COMPILER_GENERATE_SWIFT_ASSET_SYMBOL_EXTENSIONS=NO ASSETCATALOG_COMPILER_GENERATE_ASSET_SYMBOLS=NO"
    system "cd ${worksrcpath} && ${xcodebuildcmd} -derivedDataPath ${worksrcpath}/.dd -scheme ${name} -configuration ${xcode.configuration} install ${xcode_settings}"
    file mkdir ${destroot}${applications_dir}
    foreach f [glob -nocomplain ${tmp_dstroot}${applications_dir}/*] {
        file copy -force $f ${destroot}${applications_dir}/
    }
}

post-destroot {
    catch {file delete -force /tmp/eul-build}
    catch {file delete -force /tmp/eul-destroot}
}
