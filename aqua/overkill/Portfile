PortSystem          1.0
PortGroup           github 1.0
PortGroup           xcode 1.0

github.setup        KrauseFx overkill-for-mac b8ba6dc

name                overkill
version             1.0_p20230427
categories          aqua sysutils
license             MIT
maintainers         {gmail.com:audvare @Tatsh}

description         Temporarily block certain apps from opening.
long_description    Did iTunes ever launch without you opening it? Use Overkill to instantly \
                    kill the iTunes process once it opened itself, so your workflow isn’t \
                    interrupted.
homepage            https://github.com/KrauseFx/overkill-for-mac

checksums           rmd160  6b4a87c68165cb8ff04ec87759b5d04791ac1187 \
                    sha256  15f42201965b46d3bb1bbaa8fe7a7fa5641c1f08c76dc62d870bbc8abdc9a9e8 \
                    size    119849

xcode.target        Overkill
xcode.scheme        Overkill
xcode.configuration Release
xcode.build.settings    SDKROOT=macosx \
    OBJROOT=${workpath}/obj \
    SYMROOT=${workpath}/sym \
    ASSETCATALOG_COMPILER_GENERATE_ASSET_SYMBOLS=NO
xcode.destroot.settings \
    SDKROOT=macosx \
    CODE_SIGN_IDENTITY=- \
    CODE_SIGN_STYLE=Manual \
    ENABLE_HARDENED_RUNTIME=NO

# Build in build phase (writes to workpath); destroot only copies (avoids ibtool "Operation not permitted" on install).
build.pre_args      -derivedDataPath ${workpath}/.dd
build.env-append    TMPDIR=${workpath}/tmp
pre-build {
    foreach d { .dd obj sym tmp } {
        file mkdir ${workpath}/${d}
    }
    catch { exec chmod -R u+rwx,g+rwx,o+rwx ${workpath}/obj ${workpath}/sym ${workpath}/.dd ${workpath}/tmp }
}
destroot {
    xcode::fix_resource_dependencies
    xinstall -m 755 -d ${destroot}/Applications/MacPorts
    file copy ${workpath}/sym/Release/Overkill.app \
        ${destroot}/Applications/MacPorts/
}

patchfiles          patch-swift-fixes.diff

if {${os.major} < 14} {
    pre-fetch {
        ui_error "${name} @${version} requires OS X 10.10 or later."
        return -code error "incompatible OS X version"
    }
}

# Build in build phase; destroot only copies (see destroot {} above).
