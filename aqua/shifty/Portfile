PortSystem          1.0
PortGroup           github 1.0
PortGroup           xcode 1.0

github.setup        thompsonate Shifty 1.2 v
# Use source tarball from tag; release asset returns 404
github.tarball_from tarball

categories-append   sysutils
license             GPL-3
maintainers         {gmail.com:audvare @Tatsh}
description         A macOS menu bar app that gives you more control over Night Shift.
long_description    ${description}
homepage            https://shifty.natethompson.io/en/

checksums           rmd160  0e1673809727d9d9a7686c957498dfc7fe961b82 \
                    sha256  69eaf76fa83da25a25749086525c3ba277dfd298f20de01aa581f96986b980a0 \
                    size    59296370

xcode.scheme        Shifty
xcode.configuration Release
xcode.build.settings \
    SDKROOT=macosx \
    CODE_SIGN_IDENTITY=- \
    CODE_SIGN_STYLE=Manual \
    PROVISIONING_PROFILE_SPECIFIER= \
    DEVELOPMENT_TEAM= \
    ENABLE_HARDENED_RUNTIME=NO
# Build and install to /tmp so sandboxed ibtool can write NIBs (avoids "Operation not permitted" under /opt).
set _xcode_build_dir /tmp/Shifty-build-[pid]
set _xcode_destroot_tmp /tmp/Shifty-destroot-[pid]
xcode.destroot.settings \
    OBJROOT=${_xcode_build_dir} \
    SYMROOT=${_xcode_build_dir} \
    SDKROOT=macosx \
    CODE_SIGN_IDENTITY=- \
    CODE_SIGN_STYLE=Manual \
    PROVISIONING_PROFILE_SPECIFIER= \
    DEVELOPMENT_TEAM= \
    ENABLE_HARDENED_RUNTIME=NO
# Fix PublicSuffix pod: rename var to avoid collision with URL in newer SDK
# Fix CocoaPods embed script: resolve framework symlinks relative to symlink dir
# so ../../UninstalledProducts/macosx works with -derivedDataPath in worksrcpath
pre-configure {
    reinplace "s/private var applicationSupportDirectory/private var pslAppSupportDir/" \
        ${worksrcpath}/Pods/PublicSuffix/PublicSuffix/PublicSuffix.swift
    reinplace "s/etld_path = applicationSupportDirectory/etld_path = pslAppSupportDir/g" \
        ${worksrcpath}/Pods/PublicSuffix/PublicSuffix/PublicSuffix.swift
    set embed_sh [file join ${worksrcpath} "Pods" "Target Support Files" "Pods-Shifty" "Pods-Shifty-frameworks.sh"]
    set f [open ${embed_sh} r]
    set content [read $f]
    close $f
    set old {  if [ -L "${source}" ]; then
    echo "Symlinked..."
    source="$(readlink "${source}")"
  fi}
    set new {  if [ -L "${source}" ]; then
    echo "Symlinked..."
    link_target="$(readlink "${source}")"
    source_dir="$(cd "$(dirname "${source}")" && pwd)"
    case "${link_target}" in
      /*) source="${link_target}" ;;
      *) source="${source_dir}/${link_target}" ;;
    esac
  fi}
    set content [string map [list $old $new] $content]
    set f [open ${embed_sh} w]
    puts -nonewline $f $content
    close $f
}

destroot.pre_args   -workspace Shifty.xcworkspace \
                    -derivedDataPath ${_xcode_build_dir}
# Override DSTROOT last so sandboxed ibtool can write (port base appends DSTROOT=destroot otherwise).
destroot.post_args  DSTROOT=${_xcode_destroot_tmp}

patchfiles      patch-macports.diff
patch.pre_args  -p1

# Copy from temp DSTROOT (used so sandboxed ibtool can write) into real destroot.
post-destroot {
    system "rsync -a ${_xcode_destroot_tmp}/ ${destroot}/"
}

# Compile and install in one step, for now. See https://trac.macports.org/ticket/57137
build {}

if {${os.major} < 21} {
    pre-fetch {
        ui_error "Building ${name} @${version} requires macOS 12 or later."
        return -code error "incompatible macOS version"
    }
}
