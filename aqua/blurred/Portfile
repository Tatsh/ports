# -*- coding: utf-8; mode: tcl; tab-width: 4; indent-tabs-mode: nil; c-basic-offset: 4 -*- vim:fenc=utf-8:ft=tcl:et:sw=4:ts=4:sts=4

PortSystem          1.0

PortGroup           github 1.0
PortGroup           xcode 1.0

github.setup        dwarvesf blurred 1.2.0 v
# Release asset is .dmg only; use source tarball from tag
github.tarball_from tarball

categories          aqua sysutils
platforms           macosx
maintainers         {gmail.com:audvare @Tatsh} openmaintainer
license             GPL-2
supported_archs     arm64 x86_64

description         macOS status monitoring app written in SwiftUI.
long_description    ${description}

checksums           rmd160  538713b17492b3a13db724c8b6345f00acd9352e \
                    sha256  0a6a431010eb4ac357612f15eb4c567eec2e2bc2a8e5f165ef7600507f6e94e7 \
                    size    27836470

depends_lib port:HotKey

if {${os.major} < 19} {
    known_fail      yes
    pre-fetch {
        ui_error "${name} requires macOS 10.15 or later."
        return -code error "incompatible macOS version"
    }
}

patchfiles patch-deps.diff

# Build and install under /tmp so actool/ibtool can write (sandbox blocks writes under /opt/local).
set tmpbuild /tmp/macports-${name}-build
set tmpdest  ${tmpbuild}/destroot
destroot.dir          ${tmpbuild}/${name}-${version}
destroot.destdir      DSTROOT=${tmpdest}
xcode.destroot.settings \
    SDKROOT=macosx \
    CODE_SIGN_IDENTITY=- \
    CODE_SIGN_STYLE=Manual \
    ENABLE_HARDENED_RUNTIME=NO \
    OBJROOT=${tmpbuild}/obj \
    SYMROOT=${tmpbuild}/sym \
    ASSETCATALOG_COMPILER_GENERATE_ASSET_SYMBOLS=NO
destroot.pre_args -derivedDataPath ${tmpbuild}/.dd
destroot.env-append   TMPDIR=${tmpbuild}/tmp

xcode.configuration Release
xcode.scheme        Blurred
xcode.build.settings    SDKROOT=macosx

pre-destroot {
    file delete -force ${tmpbuild}
    file mkdir ${tmpbuild}
    file mkdir ${tmpdest}
    file copy -force ${worksrcpath} ${tmpbuild}/${name}-${version}
    foreach d { obj sym .dd tmp } {
        file mkdir ${tmpbuild}/${d}
    }
}

post-destroot {
    # Copy xcode install from tmp destroot into real destroot (actool/ibtool cannot write under /opt/local).
    set app_src ${tmpdest}/Applications/MacPorts/Blurred.app
    set app_dst ${destroot}/Applications/MacPorts/Blurred.app
    if {[file exists ${app_src}]} {
        xinstall -d ${destroot}/Applications/MacPorts
        file copy -force ${app_src} ${app_dst}
    }
    catch { file delete -force ${tmpbuild} }
}

# Compile and install in one step, for now. See https://trac.macports.org/ticket/57137
build {}
